<h1>🔒 Cyber Password Manager</h1><div id="box" class="container"><div id="loginBox"><h3>Masukkan PIN</h3><input type="password" id="pinInput">
<br>
<button onclick="login()">Login PIN</button>
<button id="googleBtn">Login Google</button></div><div id="app" class="hidden"><input id="search" placeholder="Search password..." onkeyup="searchPass()"><h3>Tambah Password</h3><input id="site" placeholder="Website">
<input id="username" placeholder="Username">
<input id="password" placeholder="Password"><br><button onclick="generate()">Generate</button>
<button onclick="addPass()">Add Password</button>

<p>Total Password: <span id="count">0</span></p><div id="list"></div></div></div><script>

/* DOM */

let box=document.getElementById("box")
let loginBox=document.getElementById("loginBox")
let app=document.getElementById("app")

let siteInput=document.getElementById("site")
let userInput=document.getElementById("username")
let passInput=document.getElementById("password")

let list=document.getElementById("list")
let count=document.getElementById("count")
let search=document.getElementById("search")

/* ======================
DRAG SYSTEM
====================== */

let dragging=false
let startX,startY
let boxX,boxY

let vx=0
let vy=0

const DRAG_POWER=0.07
const MAX_SPEED=9

function validTarget(el){
return !(el.tagName==="INPUT"||el.tagName==="BUTTON")
}

box.addEventListener("mousedown",e=>{

if(!validTarget(e.target))return

dragging=true
startX=e.clientX
startY=e.clientY

boxX=box.offsetLeft
boxY=box.offsetTop

})

document.addEventListener("mousemove",e=>{

if(!dragging)return

let dx=e.clientX-startX
let dy=e.clientY-startY

vx=dx*DRAG_POWER
vy=dy*DRAG_POWER

vx=Math.max(-MAX_SPEED,Math.min(MAX_SPEED,vx))
vy=Math.max(-MAX_SPEED,Math.min(MAX_SPEED,vy))

box.style.left=boxX+dx+"px"
box.style.top=boxY+dy+"px"

})

document.addEventListener("mouseup",()=>dragging=false)

/* TOUCH */

box.addEventListener("touchstart",e=>{

if(!validTarget(e.target))return

let t=e.touches[0]

dragging=true

startX=t.clientX
startY=t.clientY

boxX=box.offsetLeft
boxY=box.offsetTop

})

document.addEventListener("touchmove",e=>{

if(!dragging)return

let t=e.touches[0]

let dx=t.clientX-startX
let dy=t.clientY-startY

vx=dx*DRAG_POWER
vy=dy*DRAG_POWER

vx=Math.max(-MAX_SPEED,Math.min(MAX_SPEED,vx))
vy=Math.max(-MAX_SPEED,Math.min(MAX_SPEED,vy))

box.style.left=boxX+dx+"px"
box.style.top=boxY+dy+"px"

})

document.addEventListener("touchend",()=>dragging=false)

/* ======================
PHYSICS
====================== */

function physics(){

if(!dragging){

let x=box.offsetLeft+vx
let y=box.offsetTop+vy

vx*=0.96
vy*=0.96

if(x<=0||x+box.offsetWidth>=window.innerWidth){

if(Math.abs(vx)>7) breakGlass()

vx*=-1

}

if(y<=0||y+box.offsetHeight>=window.innerHeight){

if(Math.abs(vy)>7) breakGlass()

vy*=-1

}

box.style.left=x+"px"
box.style.top=y+"px"

}

requestAnimationFrame(physics)

}

physics()

/* ======================
GLASS BREAK SOUND
====================== */

function playGlassSound(){

let ctx=new (window.AudioContext||window.webkitAudioContext)()

let buffer=ctx.createBuffer(1,44100,44100)
let data=buffer.getChannelData(0)

for(let i=0;i<data.length;i++){

data[i]=(Math.random()*2-1)*(1-i/data.length)

}

let src=ctx.createBufferSource()
src.buffer=buffer

let gain=ctx.createGain()
gain.gain.value=0.4

src.connect(gain)
gain.connect(ctx.destination)

src.start()

}

/* ======================
GLASS BREAK
====================== */

function breakGlass(){

playGlassSound()

box.style.display="none"

for(let i=0;i<40;i++){

let shard=document.createElement("div")
shard.className="shard"

let size=10+Math.random()*30

shard.style.width=size+"px"
shard.style.height=size+"px"

document.body.appendChild(shard)

let x=box.offsetLeft+Math.random()*box.offsetWidth
let y=box.offsetTop+Math.random()*box.offsetHeight

let vx=(Math.random()-0.5)*15
let vy=(Math.random()-0.5)*15

let rot=Math.random()*360
let vr=(Math.random()-0.5)*20

function move(){

x+=vx
y+=vy

vy+=0.5
rot+=vr

shard.style.left=x+"px"
shard.style.top=y+"px"

shard.style.transform="rotate("+rot+"deg)"

let op=parseFloat(shard.style.opacity||1)
op-=0.01
shard.style.opacity=op

if(y<window.innerHeight && op>0){
requestAnimationFrame(move)
}else{
shard.remove()
}

}

shard.style.left=x+"px"
shard.style.top=y+"px"

move()

}

}

/* ======================
PASSWORD STRENGTH
====================== */

function passwordStrength(pass){

let score=0

if(pass.length>=8) score+=20
if(pass.length>=12) score+=20
if(/[A-Z]/.test(pass)) score+=15
if(/[a-z]/.test(pass)) score+=15
if(/[0-9]/.test(pass)) score+=15
if(/[^A-Za-z0-9]/.test(pass)) score+=15

return Math.min(score,100)

}

function strengthColor(score){

if(score<40) return "red"
if(score<70) return "orange"
return "lime"

}

/* AES */

async function getKey(){

let raw=await crypto.subtle.digest(
"SHA-256",
new TextEncoder().encode("CyberSecretKey")
)

return crypto.subtle.importKey(
"raw",
raw,
{name:"AES-GCM"},
false,
["encrypt","decrypt"]
)

}

async function encrypt(text){

let key=await getKey()

let iv=crypto.getRandomValues(new Uint8Array(12))

let enc=await crypto.subtle.encrypt(
{name:"AES-GCM",iv},
key,
new TextEncoder().encode(text)
)

return btoa(JSON.stringify({
iv:Array.from(iv),
data:Array.from(new Uint8Array(enc))
}))

}

async function decrypt(text){

let key=await getKey()

let obj=JSON.parse(atob(text))

let iv=new Uint8Array(obj.iv)
let data=new Uint8Array(obj.data)

let dec=await crypto.subtle.decrypt(
{name:"AES-GCM",iv},
key,
data
)

return new TextDecoder().decode(dec)

}

/* PIN */

let pin=localStorage.getItem("pin")

if(!pin){
pin=prompt("Buat PIN baru")
localStorage.setItem("pin",pin)
}

function login(){

let input=document.getElementById("pinInput").value

if(input===pin){
loginBox.classList.add("hidden")
app.classList.remove("hidden")
show()
}else{
alert("PIN salah")
}

}

/* DATA */

let data=JSON.parse(localStorage.getItem("passData"))||[]

function save(){
localStorage.setItem("passData",JSON.stringify(data))
}

/* ADD */

async function addPass(){

let site=siteInput.value
let user=userInput.value
let pass=passInput.value

if(!site||!user||!pass){
alert("Isi semua data!")
return
}

let encrypted=await encrypt(pass)

data.push({
site,
user,
pass:encrypted
})

save()
show()

}

/* SHOW */

async function show(){

list.innerHTML=""

for(let i=0;i<data.length;i++){

let plain=await decrypt(data[i].pass)

let score=passwordStrength(plain)
let color=strengthColor(score)

list.innerHTML+=`

<div class="item">

<b>${data[i].site}</b><br>
User: ${data[i].user}<br>

Pass: <span id="p${i}">••••••</span><br>

Security:
<span style="color:${color}">
${score}%
</span>

<br>

<button onclick="toggle(${i})">Show</button>
<button onclick="copyPass(${i})">Copy</button>
<button onclick="del(${i})">Delete</button>

</div>

`

}

count.innerText=data.length

}

/* TOGGLE */

async function toggle(i){

let el=document.getElementById("p"+i)

if(el.innerText==="••••••"){
let dec=await decrypt(data[i].pass)
el.innerText=dec
}else{
el.innerText="••••••"
}

}

/* COPY */

async function copyPass(i){

let dec=await decrypt(data[i].pass)

navigator.clipboard.writeText(dec)

alert("Password copied!")

}

/* DELETE */

function del(i){
data.splice(i,1)
save()
show()
}

/* GENERATE */

function generate(){

let chars="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%"

let pass=""

for(let i=0;i<12;i++){
pass+=chars[Math.floor(Math.random()*chars.length)]
}

passInput.value=pass

}

/* SEARCH */

function searchPass(){

let keyword=search.value.toLowerCase()

let items=document.querySelectorAll(".item")

items.forEach(item=>{

if(item.innerText.toLowerCase().includes(keyword)){
item.style.display="block"
}else{
item.style.display="none"
}

})

}

/* PARTICLES */

let canvas=document.getElementById("bg")
let ctx=canvas.getContext("2d")

function resize(){
canvas.width=innerWidth
canvas.height=innerHeight
}

resize()
window.addEventListener("resize",resize)

let particles=[]

for(let i=0;i<150;i++){

particles.push({
x:Math.random()*canvas.width,
y:Math.random()*canvas.height,
size:Math.random()*2,
speed:Math.random()*1
})

}

function animate(){

ctx.clearRect(0,0,canvas.width,canvas.height)

ctx.fillStyle="#ff0000"

particles.forEach(p=>{

ctx.beginPath()
ctx.arc(p.x,p.y,p.size,0,Math.PI*2)
ctx.fill()

p.y+=p.speed

if(p.y>canvas.height)p.y=0

})

requestAnimationFrame(animate)

}

animate()
